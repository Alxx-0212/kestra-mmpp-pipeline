# Copy this file to .env_encoded and replace each value with a base64-encoded
# value before running Kestra locally.
#
# Example:
#   printf '%s' 'real-secret-value' | base64 -w0

# Google service account JSON for {{ secret('GCP_SA_KEY') }}
SECRET_GCP_SA_KEY=e30=

# Telegram alerting secrets
SECRET_TELEGRAM_BOT_TOKEN=Y2hhbmdlLW1l
SECRET_TELEGRAM_CHAT_ID=Y2hhbmdlLW1l

# FinPay workflow database settings
SECRET_FINPAY_DB_HOST=ZmlucGF5LXBvc3RncmVz
SECRET_FINPAY_DB_PORT=NTQzMg==
SECRET_FINPAY_DB_NAME=ZmlucGF5
SECRET_FINPAY_DB_USER=ZmlucGF5
SECRET_FINPAY_DB_PASSWORD=Y2hhbmdlLW1l

# Google Sheets access/protection settings
# Use X19FTVBUWV9f, base64 for __EMPTY__, for intentionally blank optional lists.
SECRET_FINPAY_SPREADSHEET_WRITER_EMAILS=b3duZXJAZXhhbXBsZS5jb20=
SECRET_FINPAY_SPREADSHEET_LOCALE=ZW5fR0I=
