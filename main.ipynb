import re

# Fee validation rules per transaction type
# Format: txn_type -> {fee_type: expected_total_debet, ...}
# SELLTHRUSALESFEE has no debet requirement, just presence check -> None
FEE_RULES = {
    'RECHARGE':  {'RECHARGEFEE':      20,   },
    'SELLTHRU':  {'SELLTHRUFEE':      100,  'SELLTHRUSALESFEE': None},
}


def flag_unusual_transactions(df: pd.DataFrame) -> pd.DataFrame:
    '''
    Returns all rows (main + fee) belonging to transaction groups
    that violate the expected fee rules.

    Rules:
      RECHARGE   : must have RECHARGEFEE with total Debet == 20
      SELLTHRU   : must have SELLTHRUFEE with total Debet == 100
                   AND at least 1 SELLTHRUSALESFEE row

    A new column `unusual_reason` is added to describe why the group failed.
    '''
    df = df.copy()

    # Extract base_id: strip trailing SALESFEE or FEE from Transaction ID
    df['base_id'] = df['Transaction ID'].str.replace(r'(SLSFEE|FEE)$', '', regex=True)

    unusual_base_ids: dict[str, str] = {}  # base_id -> reason

    for base_id, group in df.groupby('base_id', sort=False):
        main_rows = group[~group['Transaction'].str.endswith('FEE')]
        if main_rows.empty:
            continue

        txn_type = main_rows['Transaction'].iloc[0]
        rules = FEE_RULES.get(txn_type)
        if rules is None:
            continue  # not a monitored transaction type

        # RECHARGE 'out cluster' transactions are exempt from RECHARGEFEE requirement
        OUT_CLUSTER_PHRASE = 'biaya pembelian recharge out cluster'
        is_out_cluster = (
            txn_type == 'RECHARGE'
            and main_rows['Remarks'].str.lower().str.contains(OUT_CLUSTER_PHRASE, regex=False).any()
        )

        reasons = []
        for fee_type, expected_debet in rules.items():
            if is_out_cluster and fee_type == 'RECHARGEFEE':
                continue  # exempt: out-cluster recharge needs no fee
            fee_rows = group[group['Transaction'] == fee_type]
            if fee_rows.empty:
                reasons.append(f'missing {fee_type}')
            elif expected_debet is not None:
                actual = fee_rows['Debet'].sum()
                if actual != expected_debet:
                    reasons.append(f'{fee_type} Debet={actual} (expected {expected_debet})')

        if reasons:
            unusual_base_ids[base_id] = '; '.join(reasons)

    # Filter original rows to unusual groups only
    mask = df['base_id'].isin(unusual_base_ids)
    result = df[mask].copy()
    result['unusual_reason'] = result['base_id'].map(unusual_base_ids)
    result = result.sort_values(['base_id', 'No']).reset_index(drop=True)

    print(f"Unusual transaction groups : {result['base_id'].nunique()}")
    print(f"Total rows flagged         : {len(result)}")
    return result


unusual_df = flag_unusual_transactions(relabeled_df)
unusual_df
