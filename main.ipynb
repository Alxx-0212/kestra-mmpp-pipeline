# ─────────────────────────────────────────────────────────────────────────────
# PREPROCESSING: Relabel RECHARGE out-cluster transactions
# If a RECHARGE row's Remarks contains 'fee pembelian recharge out cluster'
# (case-insensitive), rename its Transaction to 'RECHARGE OUT CLUSTER' and
# the corresponding RECHARGEFEE rows to 'RECHARGE OUT CLUSTER FEE'.
# ─────────────────────────────────────────────────────────────────────────────

OUT_CLUSTER_REMARK = 'fee pembelian recharge out cluster'


def relabel_out_cluster_transactions(df: pd.DataFrame) -> pd.DataFrame:
    '''
    Relabels RECHARGE / RECHARGEFEE rows that belong to out-cluster transactions:
      RECHARGE    -> RECHARGE OUT CLUSTER
      RECHARGEFEE -> RECHARGE OUT CLUSTER FEE

    Matching is done via Remarks containing OUT_CLUSTER_REMARK (case-insensitive).
    '''
    df = df.copy()

    # Derive base_id once for grouping (same logic as flag_unusual_transactions)
    df['_base_id'] = df['Transaction ID'].str.replace(r'(SLSFEE|SALESFEE|FEE)$', '', regex=True)

    # Find base_ids of out-cluster RECHARGE groups
    out_cluster_mask = (
        (df['Transaction'] == 'RECHARGE')
        & df['Remarks'].str.lower().str.contains(OUT_CLUSTER_REMARK, regex=False)
    )
    out_cluster_base_ids = set(df.loc[out_cluster_mask, '_base_id'])

    # Relabel Transaction column for affected rows
    in_group = df['_base_id'].isin(out_cluster_base_ids)
    df.loc[in_group & (df['Transaction'] == 'RECHARGE'),    'Transaction'] = 'RECHARGE OUT CLUSTER'
    df.loc[in_group & (df['Transaction'] == 'RECHARGEFEE'), 'Transaction'] = 'RECHARGE OUT CLUSTER FEE'

    relabeled_count = out_cluster_base_ids.__len__()
    print(f'Out-cluster groups relabeled: {relabeled_count}')

    return df.drop(columns='_base_id')


relabeled_df = relabel_out_cluster_transactions(validated_df)
relabeled_df[relabeled_df['Transaction'].str.startswith('RECHARGE OUT CLUSTER')].head(10)
