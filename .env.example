# Copy this file to .env and replace placeholder values before running Docker Compose.
# Kestra workflow secrets belong in .env_encoded, not in this file.

# Kestra metadata database
KESTRA_POSTGRES_DB=kestra
KESTRA_POSTGRES_USER=kestra
KESTRA_POSTGRES_PASSWORD=change-me
KESTRA_BASIC_AUTH_USERNAME=admin@example.com
KESTRA_BASIC_AUTH_PASSWORD=change-me

# FinPay application database container
FINPAY_DB_NAME=finpay
FINPAY_DB_USER=finpay
FINPAY_DB_PASSWORD=change-me

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me
